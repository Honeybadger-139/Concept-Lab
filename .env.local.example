# Local mode toggle:
# false = no login required (recommended for local development)
# true  = enforce Google/GitHub OAuth login
CONCEPTLAB_AUTH_ENABLED=false

# Local fallback user id when auth is disabled
CONCEPTLAB_LOCAL_USER_ID=local-dev-user

# Auth.js secret (generate a long random string)
AUTH_SECRET=your_auth_secret_here

# Google OAuth app credentials
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# GitHub OAuth app credentials
AUTH_GITHUB_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret

# Optional allowlist (comma-separated emails).
# If empty, any verified OAuth email can sign in.
ALLOWED_EMAILS=

# Provider selection: auto | ollama | openai
# auto = try ollama first, then openai (if key exists)
TOPIC_CHAT_PROVIDER=auto

# Ollama (recommended for local true LLM mode)
OLLAMA_BASE_URL=http://127.0.0.1:11434
TOPIC_CHAT_OLLAMA_MODEL=llama3.2

# Optional global/default model override used if provider-specific model is not set
TOPIC_CHAT_MODEL=llama3.2

# Optional OpenAI fallback
OPENAI_API_KEY=your_openai_api_key_here
TOPIC_CHAT_OPENAI_MODEL=gpt-4o-mini

# Optional LangFuse observability for per-user topic chatbot usage
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASEURL=https://cloud.langfuse.com
